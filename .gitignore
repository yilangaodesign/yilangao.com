# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# playground (subdirectory Next.js app)
/playground/.next/
/playground/node_modules/

# ascii-tool (subdirectory Next.js app)
/ascii-tool/.next/
/ascii-tool/node_modules/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cursor/debug-*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# payload
/src/app/(payload)/admin/importMap.js
/src/payload-types.ts
/media
