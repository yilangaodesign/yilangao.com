{
  "name": "@yilangaodesign/design-system",
  "version": "0.0.0",
  "description": "Élan Design System — React components and design tokens by Yilan Gao",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles.css",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./scss": {
      "sass": "./scss/_index.scss"
    },
    "./scss/*": {
      "sass": "./scss/*"
    },
    "./css/*": {
      "sass": "./css/*"
    }
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "framer-motion": ">=10",
    "lucide-react": ">=0.300",
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "cmdk": "^1.1.1",
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "sass": "^1.98.0",
    "postcss": "^8.0.0",
    "postcss-modules": "^6.0.0",
    "typescript": "^5",
    "framer-motion": "^11.0.0"
  },
  "scripts": {
    "build:scss": "node scripts/compile-scss.mjs",
    "build:js": "tsup",
    "build": "npm run build:scss && npm run build:js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "scss",
    "css"
  ]
}
